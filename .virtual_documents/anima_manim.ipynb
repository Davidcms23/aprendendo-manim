get_ipython().run_cell_magic("manim", " -p DesafioModuloQuatro", """
class DesafioModuloQuatro(Scene):
    def construct(self):
        titulo = Text("Resolvendo para x")
        titulo.to_edge(UP)
        
        passo_1 = MathTex("x^2", "-", "4", "=", "0")
        passo_2 = MathTex("x^2", "=", "4")
        passo_3 = MathTex("x", "=", r"\pm", "2") 
        
        passo_1.set_color_by_tex("x^2", YELLOW)
        passo_2.set_color_by_tex("x^2", YELLOW)
        passo_3.set_color_by_tex("x", YELLOW)
        
        self.play(FadeIn(titulo))
        self.play(Write(passo_1))
        self.wait(1)
        
        self.play(TransformMatchingTex(passo_1, passo_2))
        self.wait(1)
        
        self.play(TransformMatchingTex(passo_2, passo_3))
        self.wait(2)""")




















