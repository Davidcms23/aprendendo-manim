get_ipython().run_cell_magic("manim", " -pql ExerciciosAgrupamento", """
class ExerciciosAgrupamento(Scene):
    def construct(self):
        texto1 = Text("Pronto").shift(UP, LEFT*3)
        texto2 = Text("Atenção").shift(ORIGIN, LEFT*3)
        texto3 = Text("Vai").shift(DOWN, LEFT*3)
        texto4 = Text("Pronto").shift(UP, RIGHT*3)
        texto5 = Text("Atenção").shift(ORIGIN, RIGHT*3)
        texto6 = Text("Vai").shift(DOWN, RIGHT*3)

        # padrão: lag_ratio=0
        self.play(
            AnimationGroup(
                FadeIn(texto1),
                FadeIn(texto2),
                FadeIn(texto3),
            )
        )
        self.wait(0.5)

        # padrão: lag_ratio=0.05
        self.play(
            LaggedStart(
                FadeIn(texto4),
                FadeIn(texto5),
                FadeIn(texto6)
            )
        )""")

















