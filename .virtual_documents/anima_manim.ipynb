get_ipython().run_cell_magic("manim", " -pql ExercicioFinal", """
class ExercicioFinal(Scene):
    def construct(self):
        ax = Axes(
            x_range=[-1, 4, 1],
            y_range=[-1, 10, 2]
        )
        grafico = ax.plot(lambda x: x**3 - 3*x**2 + 4, color=BLUE)
        equacao = MathTex("x^3 - 3x^2 + 4", font_size=34)
        formula = MathTex("\\int^{2}_{0}(x^3 - 3x^2 + 4)dx", font_size=34)
        area = ax.get_area(grafico, x_range=[0, 2], color=PURPLE, opacity=.5)
            

        self.add(ax)
        self.play(Write(equacao))
        self.wait()
        self.play(Create(grafico), run_time=2)
        self.play(equacao.animate.shift(RIGHT*3, UP*3))
        
        self.play(Write(formula), run_time=3)
        self.play(Indicate(formula), color=PURPLE)
        self.wait()
        self.play(FadeIn(area), run_time=3)
        self.wait(2)""")






